# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.coverage
.coverage.*
htmlcov/

# mitmproxy CA (never commit private keys / local CA)
.mitmproxy/
*.pem
*.p12
!mitmproxy-ca-cert.pem.example

# OS / editor
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/

# config_io atomic-write artifacts (backup + temp)
src/config.json.bak
src/config.json.tmp

# User config — auto-generated from src/config.default.json on first run
src/config.json
tests/ui/_artifacts/

# Raw mitmproxy captures (may contain auth tokens in headers)
captures/*.flow
captures/*.log
captures/.last-session
