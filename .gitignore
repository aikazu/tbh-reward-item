# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.coverage
.coverage.*
htmlcov/

# mitmproxy CA (never commit private keys / local CA)
.mitmproxy/
*.pem
*.p12
!mitmproxy-ca-cert.pem.example

# OS / editor
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/

# config_io atomic-write artifacts (backup + temp)
src/config.json.bak
src/config.json.tmp

# User config — auto-generated from src/config.default.json on first run
src/config.json
tests/ui/_artifacts/

# Runtime logs (TamperDetector output — TamperDetector auto-creates the dir)
logs/

# Code-graph tooling output (regenerable via /graphify)
graphify-out/
