# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.coverage
.coverage.*
htmlcov/

# mitmproxy CA (never commit private keys / local CA)
.mitmproxy/
*.pem
*.p12
!mitmproxy-ca-cert.pem.example

# OS / editor
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# Runtime / debug artifacts (regenerated by app + tests, no need to share).
logs/
tests/ui/_artifacts/

# User-specific runtime config (regenerated by config_setup.ensure_config
# on first run; each user gets their own).
src/config.json
src/config.json.bak

# Auto-generated / GUI / OS
*_autosave.py
*.desktop